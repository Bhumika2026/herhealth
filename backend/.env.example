# backend/.env.example
# Copy this to .env and fill in your values

PORT=5000

# ─── MongoDB Atlas Cluster ────────────────────────────────────────────────────
# 1. Go to https://cloud.mongodb.com
# 2. Create a cluster (M0 Free Tier works)
# 3. Add your IP to Network Access allowlist
# 4. Create a DB user under Database Access
# 5. Click Connect → Drivers → copy the connection string
MONGODB_URI=mongodb+srv://admin:123456778@cluster0.d0i00zj.mongodb.net/herhealth?appName=Cluster0
# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── Razorpay Payment Gateway ─────────────────────────────────────────────────
# 1. Sign up at https://dashboard.razorpay.com
# 2. Go to Settings → API Keys → Generate Test Key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ─── Anthropic (for server-side Sakhi AI calls if needed) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
